# App (production: HTTPS URL, no trailing slash; do not set NODE_ENV in Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Checkout is redirect-based; publishable key not required unless you add Stripe.js/Elements)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ONE_OFF_GBP_349=price_xxx

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Resend (free preview + full paid reports emailed when both are set)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional (post-MVP)
AIRROI_API_KEY=
