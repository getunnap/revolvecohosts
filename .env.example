# App (production: HTTPS URL, no trailing slash; do not set NODE_ENV in Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: canonical URL for metadataBase / OG (layout.tsx). Defaults to https://revolvecohosts.com if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (required for auth, DB, intro requests API)
# Google sign-in: enable the Google provider in Supabase Dashboard → Authentication → Providers,
# and add Site URL + Redirect URLs (e.g. http://localhost:3000/auth/callback) under URL Configuration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: host intro create, operator accept/decline, admin inserts
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — STRIPE_SECRET_KEY must be Secret key from Dashboard → Developers → API keys (starts with sk_test_ or sk_live_).
# Restricted keys (rk_test_ / rk_live_) work if they include Checkout permissions. Never use pk_ or whsec_ here.
STRIPE_SECRET_KEY=
# Webhook: checkout.session.completed, payment_intent.payment_failed, charge.refunded, invoice.paid (monthly intro credits)
STRIPE_WEBHOOK_SECRET=

# --- Listing optimisation (host checkout) ---
# Option A — Tiered Stripe products (per listing): set all four; quantity at checkout = number of listings.
# If these are set, STRIPE_PRICE_ONE_OFF_GBP_349 is not required for listing checkout.
STRIPE_PRODUCT_LISTING_OPT_1_LISTING=prod_UFYmhbSo860zrQ
STRIPE_PRODUCT_LISTING_OPT_2_TO_5_LISTINGS=prod_UHV7eIUmUqZZ0o
STRIPE_PRODUCT_LISTING_OPT_6_TO_10_LISTINGS=prod_UHV8sVr2F6FWEK
# Optional; defaults to 6–10 product if unset (you may use the same prod for 11+ as 6–10)
# STRIPE_PRODUCT_LISTING_OPT_11_PLUS_LISTINGS=prod_UHV8sVr2F6FWEK

# Option B — Legacy single price (logged-in, 1 listing only) or dynamic price_data for multi-listing without catalog
STRIPE_PRICE_ONE_OFF_GBP_349=price_xxx

# --- Co-host intro credits ---
# Packs in UI follow src/lib/operator-intro-pricing.ts (e.g. £20/intro → 5-pack £100, 10-pack £200, 25-pack £500).
# Recommended one-off: one product with a one-time GBP default price per intro; checkout uses quantity = pack size (5, 10, or 25).
STRIPE_PRODUCT_OPERATOR_INTRO_ONE_OFF=prod_UHVH1dQQtGFRYD
# Legacy alternative: fixed pack prices (quantity 1 each). Optional 25-pack if not using INTRO_ONE_OFF.
# STRIPE_PRICE_OPERATOR_PACK_5_INTROS=price_xxx
# STRIPE_PRICE_OPERATOR_PACK_10_INTROS=price_xxx
# STRIPE_PRICE_OPERATOR_PACK_25_INTROS=price_xxx

# Monthly intro allowance (Checkout mode=subscription). Credits granted on invoice.paid via webhook.
STRIPE_PRODUCT_OPERATOR_SUBSCRIPTION_5_INTROS_MONTHLY=prod_UHVE7wIcQ3PqMd
STRIPE_PRODUCT_OPERATOR_SUBSCRIPTION_10_INTROS_MONTHLY=prod_UHVCmYNFQ0NkhT
STRIPE_PRODUCT_OPERATOR_SUBSCRIPTION_25_INTROS_MONTHLY=prod_UHVFtggdeZiv1C
# Optional separate product (e.g. metered/monthly per intro) — wire in Stripe Dashboard / future code as needed
# STRIPE_PRODUCT_OPERATOR_INTRO_MONTHLY_UNIT=prod_UHVIgmocH8L6hX

# Optional: co-host portal — Stripe Payment Links (server-only URLs; opens checkout in new tab).
# STRIPE_PAYMENT_LINK_OPERATOR_MONTHLY=https://buy.stripe.com/...
# STRIPE_PAYMENT_LINK_OPERATOR_PACK_5=https://buy.stripe.com/...
# STRIPE_PAYMENT_LINK_OPERATOR_PACK_10=https://buy.stripe.com/...

# Local dev: if only one seeded operator has catalog_match_id, allow intros for mock-2/mock-3 to route to them.
# Production: leave unset or false so unmatched catalog ids return 503.
# INTRO_RESOLVE_FALLBACK_FIRST_APPROVED=true

# OpenAI (listing reports)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Resend (report emails, co-host apply, host/operator intro notifications when both are set)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional: co-host applications from /cohosts (defaults to hello@revolvecohosts.com)
# COHOST_APPLY_NOTIFY_EMAIL=

# Google Maps (Places autocomplete on /find-cohost — optional; hosts can type address manually)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional (post-MVP)
AIRROI_API_KEY=
